    "Several active items still have no note. A short note makes the history easier to read later.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Several active items still have no note. A short note makes the history easier to read later."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アクティブなアイテムのいくつかにはまだメモがありません。短いメモがあると後で履歴を読み返しやすくなります。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Varios elementos activos aún no tienen nota. Una nota breve facilita leer el historial después."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Plusieurs éléments actifs n’ont toujours pas de note. Une courte note rendra l’historique plus lisible plus tard."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "有几个活跃项目还没有备注。补一句简短说明，之后回看记录会更清楚。"
          }
        }
      }
    },
