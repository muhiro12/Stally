    "Archived because it only comes out a few times a year.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Archived because it only comes out a few times a year."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "年に数回しか使わないのでアーカイブしています。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Archivado porque solo sale unas pocas veces al año."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Archivé car il ne sort que quelques fois par an."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "因为一年只会拿出来用几次，所以已归档。"
          }
        }
      }
    },
    "Archived items are read-only. Move this item back to Home to change its marks.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Archived items are read-only. Move this item back to Home to change its marks."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アーカイブ済みアイテムは読み取り専用です。マークを変更するにはこのアイテムをホームへ戻してください。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los elementos archivados son de solo lectura. Devuelve este elemento a Inicio para cambiar sus marcas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les éléments archivés sont en lecture seule. Replacez cet élément dans Accueil pour modifier ses marques."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已归档项目为只读。若要修改其标记，请将此项目移回首页。"
          }
        }
      }
    },
