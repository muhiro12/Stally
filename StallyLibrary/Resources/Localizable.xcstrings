    "You already have a %lld-day streak in motion. Keep it alive today.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You already have a %lld-day streak in motion. Keep it alive today."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すでに %lld 日の連続記録が続いています。今日もつないでいきましょう。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ya llevas una racha de %lld días. Mantenla viva hoy."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous avez déjà une série de %lld jours en cours. Faites-la vivre aujourd’hui."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你已经在保持一段 %lld 天的连续记录了。今天也继续保持吧。"
          }
        }
      }
    }
