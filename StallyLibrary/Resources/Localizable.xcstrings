    },
    "The one I reach for on cold mornings.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The one I reach for on cold mornings."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "寒い朝につい手が伸びる一着。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El que elijo en las mañanas frías."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Celui que je prends les matins froids."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "寒冷早晨最常伸手去拿的那一件。"
          }
        }
      }
    },
    "These items have history but no marks in the selected range.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "These items have history but no marks in the selected range."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "これらのアイテムには履歴がありますが、選択した期間にはマークがありません。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Estos elementos tienen historial, pero no marcas en el rango seleccionado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ces éléments ont un historique, mais aucune marque dans la période sélectionnée."
