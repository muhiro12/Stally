    "Nothing is marked in %@ yet. One mark is enough to restart the signal.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Nothing is marked in %@ yet. One mark is enough to restart the signal."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ ではまだ何もマークされていません。1 回マークすれば流れをまた始められます。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aún no hay nada marcado en %@. Una marca basta para reactivar la señal."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rien n’est encore marqué dans %@. Une seule marque suffit pour relancer le signal."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在 %@ 中还没有任何标记。补上一条标记就能重新启动这个信号。"
          }
        }
      }
    },
