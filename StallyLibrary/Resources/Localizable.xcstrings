    "Still waiting for its first stretch of regular use.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Still waiting for its first stretch of regular use."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "まだ最初の安定した使用期間を待っています。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sigue esperando su primera etapa de uso regular."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Attend encore sa première période d’utilisation régulière."
          }
        },
