    "Exports will capture your active items, archived items, and mark history in one portable package.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Exports will capture your active items, archived items, and mark history in one portable package."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "書き出しには、アクティブなアイテム、アーカイブ済みアイテム、マーク履歴が 1 つの持ち運べるパッケージとして含まれます。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las exportaciones capturarán tus elementos activos, archivados y el historial de marcas en un solo paquete portable."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les exports regrouperont vos éléments actifs, archivés et l’historique des marques dans un seul paquet transportable."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "导出会把活跃项目、已归档项目以及标记历史一起打包成一个可携带的文件。"
          }
        }
      }
