    "Add something you genuinely reach for, then mark it on the days you choose it.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add something you genuinely reach for, then mark it on the days you choose it."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "本当に手が伸びるものを追加して、選んだ日にマークしていきましょう。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade algo a lo que realmente recurras y márcalo en los días en que lo elijas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez quelque chose vers lequel vous revenez vraiment, puis marquez-le les jours où vous le choisissez."
          }
        },
