    "Archived items are read-only. Move this item back to the Library to change history." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Archived items are read-only. Move this item back to the Library to change history."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los elementos archivados son de solo lectura. Devuelve este elemento a la Biblioteca para cambiar el historial."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les éléments archivés sont en lecture seule. Replacez cet élément dans la Bibliothèque pour modifier son historique."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アーカイブ済みアイテムは読み取り専用です。履歴を変更するには、このアイテムをライブラリへ戻してください。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "已归档项目为只读状态。若要更改历史记录，请先将此项目移回资料库。"
          }
        }
      }
    },
    "Archived items keep their history,\nso this view stays focused on preserved use rather than active rotation." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Archived items keep their history,\nso this view stays focused on preserved use rather than active rotation."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los elementos archivados conservan su historial,\nasí que esta vista se centra en el uso preservado y no en la rotación activa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les éléments archivés conservent leur historique,\npour que cette vue reste centrée sur l’usage préservé plutôt que sur la rotation active."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アーカイブ済みアイテムは履歴を保持するので、\nこの画面ではアクティブな循環ではなく、残しておきたい利用履歴に集中できます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "已归档项目会保留历史记录，\n因此这里关注的是被保留下来的使用情况，而不是当前仍在轮换的项目。"
          }
        }
      }
    },
    "Archived items stay out of the Library until you move them back." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Archived items stay out of the Library until you move them back."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los elementos archivados quedan fuera de la Biblioteca hasta que los muevas de vuelta."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les éléments archivés restent hors de la Bibliothèque jusqu’à ce que vous les y replaciez."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アーカイブ済みアイテムは、戻すまでライブラリには表示されません。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "已归档项目会一直留在资料库之外，直到你将其移回。"
          }
        }
      }
    },
