    "Create a single backup file with every item, photo, note, and mark.\nExports use the `.stallybackup` extension on top of JSON data." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Create a single backup file with every item, photo, note, and mark.\nExports use the `.stallybackup` extension on top of JSON data."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Crea un único archivo de copia de seguridad con todos los elementos, fotos, notas y marcas.\nLas exportaciones usan la extensión `.stallybackup` sobre datos JSON."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Créez un seul fichier de sauvegarde avec tous les éléments, photos, notes et marques.\nLes exports utilisent l’extension `.stallybackup` sur des données JSON."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "すべてのアイテム、写真、メモ、マークをひとつのバックアップファイルにまとめます。\n書き出しは JSON データに `.stallybackup` 拡張子を付けて保存します。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "将所有项目、照片、备注和标记打包成一个备份文件。\n导出时会以 JSON 数据为基础并使用 `.stallybackup` 扩展名。"
          }
        }
      }
    },
