        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "設定からアプリの主要ルートを直接共有できます。\nアイテム固有のリンクは、アイテムカードと詳細画面から引き続き利用できます。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Comparte las rutas principales de la app directamente desde Ajustes.\nLos enlaces específicos de cada elemento siguen disponibles desde las tarjetas y el detalle."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
