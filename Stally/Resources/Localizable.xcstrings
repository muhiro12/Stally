        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Todas las secciones de revisión están despejadas ahora mismo.\nActiva las secciones completadas en Ajustes para mantener visibles las secciones con recuento cero."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
