    "Read the collection as a pattern, not just a list.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Read the collection as a pattern, not just a list."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コレクションを単なる一覧ではなく、パターンとして読み取ります。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lee la colección como un patrón, no solo como una lista."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lisez la collection comme un motif, pas seulement comme une liste."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "把这份收藏当作一种模式来阅读，而不只是一个列表。"
          }
        }
      }
    },
    "Read the last 30 days as a pattern: activity density, streaks, and how much of Home already has history.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Read the last 30 days as a pattern: activity density, streaks, and how much of Home already has history."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "直近 30 日をひとつのパターンとして読みます。活動の密度、連続記録、そしてホームのどれだけに履歴があるかを見ます。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lee los últimos 30 días como un patrón: densidad de actividad, rachas y cuánto de Inicio ya tiene historial."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lisez les 30 derniers jours comme un motif : densité d’activité, séries et part d’Accueil ayant déjà un historique."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "把最近 30 天看作一种模式：活动密度、连续记录，以及首页中已有历史的占比。"
          }
        }
      }
    },
