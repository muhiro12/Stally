    "This space can expand into longer-range comparisons, saved reports, and trend views that look beyond one selected window." : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This space can expand into longer-range comparisons, saved reports, and trend views that look beyond one selected window."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este espacio puede ampliarse a comparaciones de mayor alcance, informes guardados y vistas de tendencias que miren más allá de una sola ventana seleccionada."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cet espace peut s’étendre à des comparaisons de plus longue durée, des rapports enregistrés et des vues de tendance allant au-delà d’une seule période sélectionnée."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "この領域は、より長期の比較、保存済みレポート、1 つの期間を超えて見るトレンド表示へ広げていけます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
