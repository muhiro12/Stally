    "Export and restore tools live in a separate workspace so higher-risk actions stay grouped together.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Export and restore tools live in a separate workspace so higher-risk actions stay grouped together."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "書き出しと復元のツールは別ワークスペースにまとめ、リスクの高い操作を一か所に集めています。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las herramientas de exportación y restauración viven en un espacio separado para agrupar las acciones de mayor riesgo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les outils d’export et de restauration se trouvent dans un espace séparé afin de regrouper les actions les plus risquées."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "导出与恢复工具位于独立工作区中，以便把风险较高的操作集中在一起。"
          }
        }
      }
    },
    "Export before higher-risk changes": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Export before higher-risk changes"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リスクの高い変更の前に書き出す"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Exporta antes de cambios de mayor riesgo"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Exportez avant les changements plus risqués"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在高风险变更前先导出"
          }
        }
      }
    },
    "Export the full library, preview imported snapshots, and keep higher-risk restore actions in one place.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Export the full library, preview imported snapshots, and keep higher-risk restore actions in one place."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ライブラリ全体を書き出し、読み込むスナップショットをプレビューし、リスクの高い復元操作を 1 か所にまとめます。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Exporta toda la biblioteca, previsualiza las instantáneas importadas y reúne en un solo lugar las restauraciones de mayor riesgo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Exportez toute la bibliothèque, prévisualisez les instantanés importés et gardez les restaurations les plus risquées au même endroit."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "导出整个资料库，预览将导入的快照，并把高风险的恢复操作集中在一个地方。"
          }
        }
      }
    },
    "Exported %@ with schema v%lld.": {
      "localizations": {
