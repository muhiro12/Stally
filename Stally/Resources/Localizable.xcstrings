    "Replace import deletes the current library first, then restores exactly what is in the backup.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Replace import deletes the current library first, then restores exactly what is in the backup."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "置換読み込みでは、まず現在のライブラリを削除し、その後バックアップに含まれる内容をそのまま復元します。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La importación por reemplazo elimina primero la biblioteca actual y luego restaura exactamente lo que hay en la copia."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L’import par remplacement supprime d’abord la bibliothèque actuelle, puis restaure exactement ce qui se trouve dans la sauvegarde."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "替换导入会先删除当前资料库，然后精确恢复备份中的内容。"
          }
        }
      }
    },
