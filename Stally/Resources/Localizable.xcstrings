    "Backup files are meant for your own archive and transfer workflow,\nnot for syncing between multiple devices at once.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Backup files are meant for your own archive and transfer workflow,\nnot for syncing between multiple devices at once."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "バックアップファイルは、自分用の保管や移行のためのものです。\n複数デバイス間の同時同期には使わないでください。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los archivos de copia están pensados para tu propio archivo y flujo de traslado,\nno para sincronizar varios dispositivos al mismo tiempo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les fichiers de sauvegarde sont pensés pour votre propre archivage et vos transferts,\npas pour une synchronisation simultanée entre plusieurs appareils."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "备份文件是为你自己的归档和迁移流程准备的，\n并不适合在多台设备之间同时同步。"
          }
        }
      }
    },
