    "Items that need a first mark, feel dormant, or look ready to return from Archive will appear here." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Items that need a first mark, feel dormant, or look ready to return from Archive will appear here."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aquí aparecerán los elementos que necesitan una primera marca, se sienten inactivos o parecen listos para volver desde Archivo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
