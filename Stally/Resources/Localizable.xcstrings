    "A compact read on streak strength, weekly steadiness, and how much activity is concentrated on weekends." : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A compact read on streak strength, weekly steadiness, and how much activity is concentrated on weekends."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una lectura compacta de la fuerza de las rachas, la estabilidad semanal y cuánto se concentra la actividad en los fines de semana."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un aperçu compact de la solidité des séries, de la régularité hebdomadaire et de la part d’activité concentrée le week-end."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "連続記録の強さ、週ごとの安定感、週末への偏りをコンパクトに読み取れます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "简要查看连续记录的强度、每周稳定性，以及活动有多少集中在周末。"
          }
        }
      }
    },
    "A few quiet details about the app and its build." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A few quiet details about the app and its build."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Algunos detalles discretos sobre la app y su compilación."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quelques détails discrets sur l’app et sa build."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このアプリとビルドに関する静かな補足です。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "关于这款应用及其构建的一些低调细节。"
          }
        }
      }
    },
    "A quick read on the items receiving the most attention and the ones drifting furthest into silence." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A quick read on the items receiving the most attention and the ones drifting furthest into silence."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una lectura rápida de los elementos que reciben más atención y de los que se están quedando más en silencio."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un aperçu rapide des éléments les plus sollicités et de ceux qui s’éloignent le plus dans le silence."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "よく使われているものと、最も静かになっているものを手早く見渡せます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "快速查看最受关注的项目，以及最久未被使用的项目。"
          }
        }
      }
    },
    "A quiet record of the things you keep choosing." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A quiet record of the things you keep choosing."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un registro discreto de las cosas que sigues eligiendo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Une trace discrète des choses que vous continuez à choisir."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "繰り返し選んでいるものを静かに記録します。"
