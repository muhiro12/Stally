    "Review gathers items that still need a first mark, feel dormant, or may deserve a return from Archive.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Review gathers items that still need a first mark, feel dormant, or may deserve a return from Archive."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "レビューには、最初のマークが必要なもの、休眠気味のもの、アーカイブから戻してよさそうなものが集まります。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Revisión reúne elementos que aún necesitan una primera marca, se sienten inactivos o quizá merezcan volver desde Archivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
