    "A few quiet details about the app and its build." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A few quiet details about the app and its build."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Algunos detalles tranquilos sobre la app y su compilación."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quelques détails discrets sur l’app et sa compilation."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アプリとビルドについての静かな補足です。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "关于这款应用及其构建的几条简短说明。"
          }
        }
      }
    },
    "A quick read on the items receiving the most attention and the ones drifting furthest into silence." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A quick read on the items receiving the most attention and the ones drifting furthest into silence."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una lectura rápida de los elementos que reciben más atención y de los que se están quedando más en silencio."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un aperçu rapide des éléments les plus sollicités et de ceux qui s’éloignent le plus dans le silence."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "よく使われているものと、最も静かになっているものを手早く見渡せます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "快速查看最受关注的项目，以及最久未被使用的项目。"
          }
        }
      }
    },
    "A quiet record of the things you keep choosing." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A quiet record of the things you keep choosing."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un registro sereno de las cosas que sigues eligiendo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un discret relevé de ce que vous continuez à choisir."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "繰り返し選んでいるものを静かに記録します。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "静静记录你持续选择的事物。"
          }
        }
      }
    },
    "A tighter read on this one item across the last 30 and 90 days." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A tighter read on this one item across the last 30 and 90 days."
