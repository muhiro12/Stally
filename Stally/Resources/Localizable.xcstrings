    },
    "This permanently removes the item and all of its marks.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This permanently removes the item and all of its marks."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この操作でアイテムとそのすべてのマークが完全に削除されます。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto elimina permanentemente el elemento y todas sus marcas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela supprime définitivement l’élément et toutes ses marques."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这会永久删除该项目及其所有标记。"
          }
        }
      }
    },
    "This removes the current library before restoring the selected backup.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This removes the current library before restoring the selected backup."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "選択したバックアップを復元する前に、現在のライブラリを削除します。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto elimina la biblioteca actual antes de restaurar la copia seleccionada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela supprime la bibliothèque actuelle avant de restaurer la sauvegarde sélectionnée."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这会在恢复所选备份之前先移除当前资料库。"
          }
        }
      }
    },
    "This space can expand into longer-range comparisons, saved reports, and trend views that look beyond one selected window.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This space can expand into longer-range comparisons, saved reports, and trend views that look beyond one selected window."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この領域は、より長期の比較、保存済みレポート、1 つの期間を超えて見るトレンド表示へ広げていけます。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este espacio puede ampliarse a comparaciones de mayor alcance, informes guardados y vistas de tendencias que miren más allá de una sola ventana seleccionada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cet espace peut s’étendre à des comparaisons de plus longue durée, des rapports enregistrés et des vues de tendance allant au-delà d’une seule période sélectionnée."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这一块之后可以扩展为更长周期的对比、已保存的报告，以及超出单一区间的趋势视图。"
          }
        }
      }
    },
    "Tips appear again when the related screen and state become relevant.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tips appear again when the related screen and state become relevant."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "関連する画面や状態が再び該当すると、ヒントがもう一度表示されます。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los consejos volverán a aparecer cuando la pantalla y el estado relacionados vuelvan a ser relevantes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les conseils réapparaissent lorsque l’écran et l’état concernés redeviennent pertinents."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当相关界面和状态再次变得适用时，提示会再次出现。"
