    "Prepare clean snapshots of your collection before you move them anywhere else.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Prepare clean snapshots of your collection before you move them anywhere else."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "どこかへ移す前に、コレクションのきれいなスナップショットを用意しておきましょう。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Prepara instantáneas limpias de tu colección antes de moverla a otro lugar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Préparez des instantanés propres de votre collection avant de la déplacer ailleurs."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在把收藏移动到其他地方之前，请先准备好干净的快照。"
          }
        }
      }
    },
    "Preview shows the snapshot contents, overlap with local items,\nand any warnings before import actions are enabled.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Preview shows the snapshot contents, overlap with local items,\nand any warnings before import actions are enabled."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "プレビューでは、スナップショットの内容、ローカル項目との重なり、\nそして読み込み操作を有効にする前の警告を確認できます。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La vista previa muestra el contenido de la instantánea, el solapamiento con los elementos locales\ny cualquier advertencia antes de habilitar las acciones de importación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L’aperçu montre le contenu de l’instantané, les recouvrements avec les éléments locaux\net les éventuels avertissements avant l’activation des actions d’import."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "预览会显示快照内容、与本地项目的重叠情况，\n以及在启用导入操作之前的所有警告。"
          }
        }
      }
    },
