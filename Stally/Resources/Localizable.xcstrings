            "state" : "translated",
            "value" : "Exports will capture your active items, archived items, and mark history in one portable package."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las exportaciones capturarán tus elementos activos, archivados y el historial de marcas en un solo paquete portable."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
