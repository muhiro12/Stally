    "Create a single backup file with every item, photo, note, and mark.\nExports use the `.stallybackup` extension on top of JSON data.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Create a single backup file with every item, photo, note, and mark.\nExports use the `.stallybackup` extension on top of JSON data."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すべてのアイテム、写真、メモ、マークを 1 つのバックアップファイルにまとめます。\n書き出しは JSON データに `.stallybackup` 拡張子を付けて保存します。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Crea un único archivo de copia con cada elemento, foto, nota y marca.\nLas exportaciones usan la extensión `.stallybackup` sobre datos JSON."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Créez un fichier de sauvegarde unique avec chaque élément, photo, note et marque.\nLes exports utilisent l’extension `.stallybackup` sur des données JSON."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将所有项目、照片、备注和标记打包成一个备份文件。\n导出会以 JSON 数据为基础，并使用 `.stallybackup` 扩展名。"
          }
        }
      }
    },
    "Create an item you can mark once when you chose it today.": {
      "localizations": {
        "en": {
