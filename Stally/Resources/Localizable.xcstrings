            "value": "Mark the item for today or move it in and out of Archive without affecting past marks."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "過去のマークはそのままに、今日分をマークしたりアーカイブへの出し入れを行えます。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Marca el elemento para hoy o muévelo dentro y fuera de Archivo sin afectar las marcas pasadas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Marquez l’élément pour aujourd’hui ou déplacez-le vers ou hors des archives sans toucher aux marques passées."
