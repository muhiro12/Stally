    "Export and restore tools live in a separate workspace so higher-risk actions stay grouped together." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Export and restore tools live in a separate workspace so higher-risk actions stay grouped together."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las herramientas de exportación y restauración viven en un espacio separado para agrupar las acciones de mayor riesgo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les outils d’export et de restauration se trouvent dans un espace séparé afin de regrouper les actions les plus risquées."
          }
