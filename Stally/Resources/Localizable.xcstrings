    "Merge import creates missing items, updates older local copies, and keeps newer local metadata when conflicts exist." : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Merge import creates missing items, updates older local copies, and keeps newer local metadata when conflicts exist."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La importación por fusión crea elementos faltantes, actualiza copias locales antiguas y conserva los metadatos locales más nuevos cuando hay conflictos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L’import par fusion crée les éléments manquants, met à jour les copies locales plus anciennes et conserve les métadonnées locales les plus récentes en cas de conflit."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "マージ読み込みでは、足りないアイテムを作成し、古いローカル内容を更新し、競合時には新しいローカルメタデータを残します。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "合并导入会创建缺失项目、更新较旧的本地副本，并在冲突时保留较新的本地元数据。"
          }
        }
      }
    },
