    "Items that have been waiting quietly without a first mark.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Items that have been waiting quietly without a first mark."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最初のマークが付かないまま静かに待っているアイテムです。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elementos que han estado esperando en silencio sin una primera marca."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Éléments qui attendent discrètement sans première marque."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "那些还在安静等待首次标记的项目。"
          }
        }
      }
    },
    "Items that need a first mark, feel dormant, or look ready to return from Archive will appear here.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Items that need a first mark, feel dormant, or look ready to return from Archive will appear here."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最初のマークが必要なもの、休眠気味のもの、アーカイブから戻してよさそうなものがここに並びます。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aquí aparecerán los elementos que necesitan una primera marca, se sienten inactivos o parecen listos para volver desde Archivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les éléments qui ont besoin d’une première marque, semblent endormis ou prêts à revenir des archives apparaîtront ici."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这里会显示那些需要首次标记、看起来已沉寂，或似乎可以从归档中回归的项目。"
          }
        }
      }
    },
    "Items whose last mark feels far enough away to revisit.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Items whose last mark feels far enough away to revisit."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最後のマークから十分に時間が空き、見直してよさそうなアイテムです。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elementos cuya última marca quedó lo bastante atrás como para revisitarlos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Éléments dont la dernière marque est suffisamment ancienne pour être revisités."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "那些距离上次标记已经够久、值得重新关注的项目。"
          }
        }
      }
    },
