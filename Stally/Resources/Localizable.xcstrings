    "Keep a recent backup close before you replace the library or test a restore." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Keep a recent backup close before you replace the library or test a restore."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ten a mano una copia reciente antes de reemplazar la biblioteca o probar una restauración."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gardez une sauvegarde récente à portée avant de remplacer la bibliothèque ou de tester une restauration."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ライブラリを置き換えたり復元を試したりする前に、最近のバックアップを手元に置いてください。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在替换资料库或测试恢复之前，请先准备好最近的备份。"
          }
        }
      }
    },
    "Keep one recent export before you try any replace-style restore.\nMerge import will preserve local items; replace import will overwrite them." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Keep one recent export before you try any replace-style restore.\nMerge import will preserve local items; replace import will overwrite them."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Guarda una exportación reciente antes de probar cualquier restauración de tipo reemplazo.\nLa importación por fusión conservará los elementos locales; la importación por reemplazo los sobrescribirá."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conservez un export récent avant d’essayer toute restauration de type remplacement.\nL’import par fusion préservera les éléments locaux ; l’import par remplacement les écrasera."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "置き換え型の復元を試す前に、最近の書き出しを 1 つ残しておいてください。\nマージ読み込みはローカル項目を保ち、置換読み込みはそれらを上書きします。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在尝试任何替换式恢复之前，请先保留一份最近的导出。\n合并导入会保留本地项目，而替换导入会覆盖它们。"
          }
        }
      }
    },
    "Keep preserved favorites close without letting them crowd the active list." : {
