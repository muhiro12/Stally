    "Archived items are read-only. Move this item back to Home to change history.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Archived items are read-only. Move this item back to Home to change history."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アーカイブ済みアイテムは読み取り専用です。履歴を変えるにはこのアイテムをホームへ戻してください。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los elementos archivados son de solo lectura. Devuelve este elemento a Inicio para cambiar el historial."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les éléments archivés sont en lecture seule. Replacez cet élément dans Accueil pour modifier l’historique."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已归档项目为只读。若要更改历史记录，请将此项目移回首页。"
          }
        }
      }
    },
    "Archived items keep their history,\nso this view stays focused on preserved use rather than active rotation.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Archived items keep their history,\nso this view stays focused on preserved use rather than active rotation."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アーカイブ済みアイテムは履歴を保ったままなので、\nこの画面では現役の循環ではなく保存された使い方に焦点を当てます。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los elementos archivados conservan su historial,\nasí que esta vista se centra en el uso preservado y no en la rotación activa."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les éléments archivés conservent leur historique,\ncette vue reste donc centrée sur l’usage préservé plutôt que sur la rotation active."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已归档项目会保留其历史记录，\n因此这里关注的是被保存下来的使用轨迹，而不是当前活跃轮换。"
          }
        }
      }
    },
    "Archived items stay out of Home until you move them back.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Archived items stay out of Home until you move them back."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アーカイブ済みアイテムは、戻すまでホームには現れません。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los elementos archivados permanecerán fuera de Inicio hasta que los devuelvas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les éléments archivés restent hors d’Accueil jusqu’à ce que vous les y remettiez."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已归档项目在你移回之前都不会出现在首页。"
          }
        }
      }
    },
    "Archived items will gather here once you clear space from Home.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Archived items will gather here once you clear space from Home."
